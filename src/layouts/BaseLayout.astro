---
import '../styles/global.css';
// Self-hosted via @fontsource — removes 2 external round-trips (fonts.googleapis.com +
// fonts.gstatic.com) that a Google Fonts <link> would otherwise cost on every page load.
// latin-only subset (no cyrillic/greek/vietnamese), and only the 4 weights the
// CSS actually requests (400 default body text, 500/600/700 explicit — 300 is
// never used anywhere in the project).
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = "Maicol Bautista – Software Developer",
  description = "Portfolio de Maicol Bautista, desarrollador de software especializado en TypeScript, Angular, Astro y Node.js. Proyectos, habilidades y contacto.",
  ogImage     = "/assets/og-image.jpg",
} = Astro.props;

const siteURL   = "https://code-musa.com";
const canonical = siteURL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Maicol Bautista">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href={canonical}>

    <!-- Open Graph -->
    <meta property="og:type"        content="website">
    <meta property="og:url"         content={canonical}>
    <meta property="og:title"       content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image"       content={`${siteURL}${ogImage}`}>
    <meta property="og:locale"      content="es_CO">

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image"       content={`${siteURL}${ogImage}`}>

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/fav.svg">
    <!-- apple-touch-icon intentionally omitted: no 180x180 PNG asset exists yet.
         A dead reference here costs iOS Safari an extra 404 request on every load.
         Add public/apple-touch-icon.png and restore this tag when the asset is ready. -->

    <!-- Resource hints -->
    <link rel="dns-prefetch" href="https://api.code-musa.com">
    <link rel="preconnect" href="https://api.code-musa.com" crossorigin>

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml">

    <!-- JSON-LD structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Maicol Bautista",
        "url": "https://code-musa.com",
        "jobTitle": "Software Developer",
        "knowsAbout": ["TypeScript", "Angular", "Astro", "Node.js", "MongoDB", "Docker", "Python"],
        "image": "https://code-musa.com/assets/profile.jpg",
        "sameAs": []
      }
    </script>
  </head>
  <body class="dark-theme">
    <!-- Blocking theme restore — runs before first paint to prevent FOUC -->
    <script>
      (function() {
        if (localStorage.getItem('theme') === 'light') {
          document.body.classList.remove('dark-theme');
        }
      })();
    </script>

    <div class="starfield">
      <div class="star-layer-1"></div>
      <div class="star-layer-2"></div>
      <div class="star-layer-3"></div>
      <div class="comet-primary"></div>
      <div class="comet-secondary"></div>
    </div>

    <slot />
  </body>
</html>
