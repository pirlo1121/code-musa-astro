<!-- is:global so styles apply to dynamically created .tag elements -->
<style is:global>
  .modal-backdrop {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
    animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .modal-container {
    position: relative;
    width: 100%;
    max-width: 800px;
    max-height: 90vh;
    max-height: 90dvh;
    background: var(--surface-bg, #ffffff);
    border-radius: 16px;
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.1),
      0 8px 10px -6px rgba(0, 0, 0, 0.1);
    animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  body.dark-theme .modal-container {
    background: rgba(17, 24, 39, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .modal-backdrop .close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 20;
    padding: 0;
  }

  .modal-backdrop .close-btn:hover {
    background: rgba(255, 255, 255, 0.9);
    color: black;
    transform: rotate(90deg) scale(1.1);
  }

  .modal-backdrop .modal-content {
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: var(--border-color) transparent;
  }

  .modal-backdrop .modal-content::-webkit-scrollbar { width: 6px; }
  .modal-backdrop .modal-content::-webkit-scrollbar-track { background: transparent; }
  .modal-backdrop .modal-content::-webkit-scrollbar-thumb {
    background-color: var(--border-color);
    border-radius: 20px;
  }

  .modal-backdrop .modal-image {
    position: relative;
    width: 100%;
    height: 350px;
    overflow: hidden;
    background-color: var(--bg-secondary);
  }

  .modal-backdrop .modal-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .modal-container:hover .modal-image img {
    transform: scale(1.05);
  }

  .modal-backdrop .modal-body {
    padding: 2rem 2.5rem;
  }

  .modal-backdrop h2 {
    margin: 0 0 0.5rem 0;
    font-size: 2rem;
    line-height: 1.2;
    color: var(--text-primary);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  body.dark-theme .modal-backdrop h2 {
    color: #f3f4f6;
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
  }

  .modal-backdrop .subtitle {
    font-size: 1.125rem;
    color: var(--accent-primary);
    margin: 0 0 1.5rem 0;
    font-weight: 500;
    opacity: 0.9;
  }

  body.dark-theme .modal-backdrop .subtitle {
    color: var(--accent-secondary);
  }

  .modal-backdrop .description {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 2rem 0;
    max-width: 65ch;
  }

  body.dark-theme .modal-backdrop .description {
    color: #9ca3af;
  }

  .modal-backdrop .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .modal-backdrop .tags .tag {
    background: var(--bg-secondary);
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    transition: all 0.2s ease;
  }

  .modal-backdrop .tags .tag:hover {
    transform: translateY(-2px);
    border-color: var(--text-primary);
  }

  body.dark-theme .modal-backdrop .tags .tag {
    background: rgba(139, 92, 246, 0.1);
    color: #ddd6fe;
    border-color: rgba(139, 92, 246, 0.2);
  }

  body.dark-theme .modal-backdrop .tags .tag:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: rgba(139, 92, 246, 0.4);
  }

  .modal-backdrop .links {
    display: flex;
    justify-content: space-around;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  body.dark-theme .modal-backdrop .links {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .modal-backdrop .links .btn {
    display: inline-flex;
    max-width: 35%;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    color: var(--text-primary);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 600;
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: var(--bg-secondary);
    border: 1px solid transparent;
  }

  .modal-backdrop .links .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .modal-backdrop .links .btn svg { width: 20px; height: 20px; }

  .modal-backdrop .links .btn-primary {
    background: var(--text-primary);
    color: var(--bg-primary);
  }

  body.dark-theme .modal-backdrop .links .btn {
    background: rgba(255, 255, 255, 0.05);
    color: #e5e7eb;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  body.dark-theme .modal-backdrop .links .btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  body.dark-theme .modal-backdrop .links .btn-primary {
    background: linear-gradient(135deg, var(--accent-primary) 0%, #7c3aed 100%);
    color: white;
    border: none;
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
  }

  body.dark-theme .modal-backdrop .links .btn-primary:hover {
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.5);
    background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
  }

  @media (max-width: 768px) {
    .modal-backdrop { padding: 1rem; align-items: center; }

    .modal-container {
      width: 95%;
      height: auto;
      margin: 0 auto;
      max-height: 85vh;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
    }

    .modal-backdrop .links .btn {
      max-width: 35%;
      padding: 0.5rem 1.5rem;
      border-radius: 6px;
      font-size: 0.75rem;
    }

    .modal-backdrop .modal-image { height: 250px; flex-shrink: 0; }
    .modal-backdrop .close-btn { top: 0.75rem; right: 0.75rem; width: 36px; height: 36px; }
    .modal-backdrop .modal-body { padding: 1.5rem; overflow-y: auto; }
    .modal-backdrop h2 { font-size: 1.75rem; }
    .modal-backdrop .links .btn { width: 100%; }
  }

  @media (max-height: 600px) and (orientation: landscape) {
    .modal-container { flex-direction: row; max-height: 90vh; border-radius: 12px; }
    .modal-backdrop .modal-image { width: 40%; height: 100%; }
    .modal-backdrop .modal-body { width: 60%; overflow-y: auto; }
  }
</style>
