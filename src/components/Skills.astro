---

<section class="skills-container">
  <h2>Skills</h2>
  <div class="skills-grid">
    {skills.map(skill => (
      <div class="skill-card" data-skill={skill.name}>
        <div class="skill-icon" set:html={skill.icon}></div>
        <span class="skill-name">{skill.name}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-container {
    padding: 0 2rem;
    background: transparent;
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease-out, color 0.15s ease-out;
    position: relative;
    z-index: 1;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
    transition: text-shadow 0.15s ease-out, color 0.15s ease-out;
    position: relative;
    padding-bottom: 1rem;
  }

  h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 2px;
    transform: translateX(-50%) scaleX(0.7);
    transform-origin: center;
    transition: transform 0.3s ease-out;
  }

  h2:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  body.dark-theme h2 {
    text-shadow: 0 0 10px var(--accent-glow);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    max-width: 900px;
    width: 100%;
  }

  .skill-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 0.75rem;
    background: var(--surface-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(8px);
    cursor: default;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease-out,
                border-color 0.3s ease-out,
                background 0.3s ease-out;
  }

  body.dark-theme .skill-card {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .skill-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary), var(--accent-primary));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease-out;
    pointer-events: none;
  }

  .skill-card:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    border-color: transparent;
    background: var(--bg-secondary);
  }

  body.dark-theme .skill-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 30px var(--accent-glow);
    background: rgba(255, 255, 255, 0.06);
  }

  .skill-card:hover::before {
    opacity: 1;
  }

  .skill-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease-out;
    color: var(--text-primary);
  }

  .skill-icon svg {
    width: 100%;
    height: 100%;
  }

  .skill-card:hover .skill-icon {
    transform: scale(1.25) rotate(-8deg);
    color: var(--accent-primary);
  }

  body.dark-theme .skill-card:hover .skill-icon {
    color: var(--accent-primary);
    filter: drop-shadow(0 0 8px var(--accent-glow));
  }

  .skill-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-align: center;
    line-height: 1.3;
    transition: color 0.3s ease-out;
  }

  .skill-card:hover .skill-name {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .skills-container { padding: 0 1.5rem; }
    h2 { font-size: 2rem; margin-bottom: 2rem; }
    .skills-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.85rem; }
    .skill-card { padding: 1.25rem 0.5rem; }
    .skill-icon { width: 2rem; height: 2rem; }
    .skill-name { font-size: 0.8rem; }
  }

  @media (max-width: 480px) {
    .skills-container { padding: 0 1rem; }
    h2 { font-size: 1.75rem; }
    .skills-grid { grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 0.65rem; }
    .skill-card { padding: 1rem 0.4rem; border-radius: 12px; }
    .skill-card::before { border-radius: 12px; }
    .skill-icon { width: 1.6rem; height: 1.6rem; }
    .skill-name { font-size: 0.75rem; }
  }
</style>
